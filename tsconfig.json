{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "plugins/xinyang-kb/dist-types",
    "rootDir": "plugins/xinyang-kb/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["plugins/xinyang-kb/src/**/*"],
  "exclude": ["node_modules", "plugins/xinyang-kb/dist", "plugins/xinyang-kb/dist-types"]
}
